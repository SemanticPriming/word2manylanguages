# History files
.Rhistory
.Rapp.history

# Session Data files
.RData

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron
~$data_cross_comparison.xlsx
.DS_Store
/.ipynb_checkpoints
/01_corpus_preprocessing/__pycache__
/02_model_training/__pycache__
/03_evaluation/__pycache__
/download/__pycache__
/deal with
/eval_results/replication/.ipynb_checkpoints
/eval_inputs/.ipynb_checkpoints
/eval_results/counts/.ipynb_checkpoints
/eval_results/norms/.ipynb_checkpoints
/05_manuscript/authorship
/05_manuscript/manuscript_files
05_manuscript/~$dataset_list.xlsx
05_manuscript/~$nuscript.docx
.env

# in-progress download temp files: minio_download.py's `minio` SDK writes to
# "{filename}.{etag}.part.minio" while downloading, then renames on completion
*.part.minio

# downloaded/trained models are large and re-downloadable (see download/README.md);
# keep just one small one tracked as a worked example, matching raw/'s pattern.
# build_models() writes .csv.bz2 directly; .csv is ignored too as a safety net
# for stray uncompressed output (e.g. from an older copy of the script).
/models/*.bz2
/models/*.csv
!/models/af_50_1_cbow_wxd.csv.bz2

# other languages' frequency-count data downloaded from MinIO's frequency_source/
# (see download/README.md); keep the af/afwiki example tracked, in whichever of
# the two formats evaluation.py's load_count_freqs reads (plain .tsv or .zip)
/eval_inputs/counts/*.tsv
/eval_inputs/counts/*.zip
!/eval_inputs/counts/dedup.af.words.unigrams.tsv
!/eval_inputs/counts/dedup.afwiki-meta.words.unigrams.tsv
!/eval_inputs/counts/dedup.af.words.unigrams.tsv.zip
!/eval_inputs/counts/dedup.afwiki-meta.words.unigrams.tsv.zip

# psycholinguistic norms datasets are large (250MB+) and sourced from many
# individual papers, not re-downloadable as a bundle; keep just one real af
# (Afrikaans) worked example tracked, matching the models/ and counts/
# pattern above. Luniewska2016.csv is the only norms file that covers af.
# datasets_norms.csv (the full catalog of every dataset/variable) stays
# tracked since it's small and doesn't depend on the raw files being present.
/eval_inputs/norms/*.csv
!/eval_inputs/norms/Luniewska2016.csv

# replication datasets (van Paridon & Thompson norms, ~13MB) have no natural
# af-language example to keep as a worked sample, so track only the README
# describing the format; see datasets_replication.csv for the full catalog.
/eval_inputs/replication/*.tsv

# 01_corpus_preprocessing/ output: regenerated by running the pipeline, unlike
# raw/'s checked-in worked example (see preprocessed/README.md, corpora/README.md)
/preprocessed/*.zip
/corpora/*.txt
temp.md
